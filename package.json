{
  "name": "compass-clinical-trial-navigator",
  "version": "1.2.0",
  "description": "Compass - Clinical Trial Navigator: a DHIS2 application for searching clinical trials across official registries, viewing structured trial detail, and producing plain-language trial explainers to support safer trial-navigation workflows.",
  "license": "BSD-3-Clause",
  "author": "Claidex",
  "homepage": ".",
  "repository": {
    "type": "git",
    "url": "https://github.com/ssatanis/claidex-dhis2.git"
  },
  "private": false,
  "scripts": {
    "start": "d2-app-scripts start",
    "build": "d2-app-scripts build",
    "test": "d2-app-scripts test --passWithNoTests",
    "lint": "d2-style check src",
    "lint:fix": "d2-style apply src",
    "typecheck": "tsc --noEmit",
    "deploy": "d2-app-scripts deploy",
    "publish": "d2-app-scripts publish"
  },
  "dependencies": {
    "@ai-sdk/react": "^3.0.193",
    "@dhis2/app-runtime": "^3.11.4",
    "@dhis2/d2-i18n": "^1.1.3",
    "@dhis2/ui": "^9.11.4",
    "ai": "^6.0.191",
    "dompurify": "^3.4.5",
    "marked": "^18.0.4",
    "pdf-lib": "^1.17.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@dhis2/cli-app-scripts": "^12.4.0",
    "@dhis2/cli-style": "^10.7.4",
    "@types/dompurify": "^3.0.5",
    "@types/jest": "^29.5.12",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=18"
  },
  "browserslist": {
    "production": [
      ">1%",
      "last 2 versions",
      "not dead"
    ],
    "development": [
      "last 2 chrome versions",
      "last 2 firefox versions"
    ]
  }
