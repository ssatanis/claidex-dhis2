# Compass — Clinical Trial Navigator — example environment configuration.
#
# Copy to `.env` for local development. All variables are OPTIONAL: the app is
# fully functional against public registries (ClinicalTrials.gov, ISRCTN)
# without any of them. These only enable the optional Claidex Compass backend
# for risk/failure-intelligence context and richer explainer generation.
#
# NEVER commit a real `.env`. See PRIVACY_AND_DATA_FLOW.md.

# Base URL of a Claidex Compass backend (risk intelligence + explainer generation).
# When unset, the app runs registry-only and the risk panel shows a clear
# "not connected" state instead of any fabricated values.
REACT_APP_CLAIDEX_API_BASE_URL=

# Optional bearer token for the Claidex backend, if the deployment requires it.
REACT_APP_CLAIDEX_API_TOKEN=

# Base URL of the Claidex Compass API that powers the AI Patient Navigator
# (streaming chat + tool calls + PDF trigger). Defaults to the hosted Claidex
# app. Point at a local Claidex instance for development, e.g.:
#   REACT_APP_COMPASS_API_BASE=http://localhost:3000
# The Compass chat endpoint must allow this app's origin via CORS.
REACT_APP_COMPASS_API_BASE=
